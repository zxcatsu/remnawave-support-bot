# --- Основные настройки бота ---
PROJECT_NAME=My VPN Support
TELEGRAM_TOKEN=123456789:AA-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_GROUP_ID=-1001234567890
BANS_TOPIC_ID=1

# --- База данных RemnaWave (Postgres) ---
PG_HOST=remnawave-db
PG_DB=postgres
PG_USER=postgres
PG_PASS=CHANGE_ME

# --- Docker-сеть ---
EXTERNAL_NETWORK_NAME=remnawave-network

# --- Автозакрытие тикетов (0 = выключено) ---
AUTO_CLOSE_HOURS=24

# --- Отзывы ---
REVIEWS_TOPIC_ID=1
REVIEWS_CHANNEL=@my_reviews_channel

# ─── Медиа-баннеры ───────────────────────────────────────────────────────────
# MENU_MEDIA — универсальный баннер (используется везде, где раздельный не задан).
# Форматы: .png .jpg .gif .mp4
MENU_MEDIA=assets/menu.png

# Раздельные баннеры (оставьте пустыми чтобы использовать MENU_MEDIA):
FAQ_MEDIA=
REVIEWS_MEDIA=
TICKET_MEDIA=

# ─── Тексты разделов (HTML) ──────────────────────────────────────────────────
# Редактируйте файлы напрямую — бот читает их при каждом запросе (без перезапуска).
MENU_TEXT_FILE=texts/menu.txt
FAQ_FILE=texts/faq.txt
REVIEWS_TEXT_FILE=texts/reviews.txt
TICKET_TEXT_FILE=texts/ticket.txt

# ─── Кнопки главного меню ────────────────────────────────────────────────────
BTN_FAQ=❓ FAQ
BTN_TICKET=🎫 Отправить тикет
BTN_REVIEWS=⭐ Отзывы

# --- Прочее ---
TZ=Europe/Moscow
# LOG_PATH=bot.log
