# --- Основные настройки бота ---
PROJECT_NAME=My VPN Support
TELEGRAM_TOKEN=123456789:AA-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_GROUP_ID=-1001234567890
BANS_TOPIC_ID=1

# --- База данных панели RemnaWave (Postgres) ---
PG_HOST=remnawave-db
PG_DB=postgres
PG_USER=postgres
PG_PASS=CHANGE_ME

# --- Docker-сеть панели RemnaWave ---
EXTERNAL_NETWORK_NAME=remnawave-network

# --- Автозакрытие тикетов (часов без активности; 0 = выключено) ---
AUTO_CLOSE_HOURS=24

# --- Отзывы ---
REVIEWS_TOPIC_ID=1
REVIEWS_CHANNEL=@my_reviews_channel

# --- Прочее ---
TZ=Europe/Moscow
# LOG_PATH=bot.log
